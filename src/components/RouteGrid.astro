---
import StatusBadge from './StatusBadge.astro';
import { currentLocale, labels } from '../data/localized-ui';

const translatedLocales = [
  'cs',
  'da',
  'de',
  'el',
  'es',
  'fi',
  'fr',
  'hu',
  'it',
  'ja',
  'ko',
  'nl',
  'no',
  'pl',
  'pt',
  'sv',
  'tr',
  'uk',
  'zh',
];
const locale = Astro.url.pathname.split('/').filter(Boolean)[0];
const prefix = translatedLocales.includes(locale) ? `/${locale}` : '';
const ui = labels[currentLocale(Astro.url.pathname)];
const searchText =
  {
    cs: 'Hledat v dokumentaci DiscVault',
    da: 'Søg i DiscVault-dokumentationen',
    de: 'DiscVault-Dokumentation durchsuchen',
    el: 'Αναζήτηση στην τεκμηρίωση DiscVault',
    es: 'Buscar en la documentación de DiscVault',
    fi: 'Hae DiscVault-ohjeista',
    fr: 'Rechercher dans la documentation DiscVault',
    hu: 'Keresés a DiscVault dokumentációban',
    it: 'Cerca nella documentazione DiscVault',
    ja: 'DiscVault ドキュメントを検索',
    ko: 'DiscVault 문서 검색',
    nl: 'DiscVault-documentatie doorzoeken',
    no: 'Søk i DiscVault-dokumentasjonen',
    pl: 'Przeszukaj dokumentację DiscVault',
    pt: 'Pesquisar na documentação do DiscVault',
    sv: 'Sök i DiscVault-dokumentationen',
    tr: 'DiscVault belgelerinde ara',
    uk: 'Пошук у документації DiscVault',
    zh: '搜索 DiscVault 文档',
  }[locale] ?? 'Search DiscVault documentation';
const serverText =
  {
    cs: 'Server',
    da: 'Server',
    de: 'Server',
    el: 'Διακομιστής',
    es: 'Servidor',
    fi: 'Palvelin',
    fr: 'Serveur',
    hu: 'Kiszolgáló',
    it: 'Server',
    ja: 'サーバー',
    ko: '서버',
    nl: 'Server',
    no: 'Server',
    pl: 'Serwer',
    pt: 'Servidor',
    sv: 'Server',
    tr: 'Sunucu',
    uk: 'Сервер',
    zh: '服务器',
  }[locale] ?? 'Server';
const routes = [
  {
    icon: '◉',
    title: serverText,
    description: 'Docker · PostgreSQL · HTTPS',
    href: '/install/',
    statuses: [
      { status: 'stable', label: ui.v26Stable },
      { status: 'beta', label: ui.v26Beta },
    ],
  },
  {
    icon: '◇',
    title: 'PWA',
    description: 'PWA',
    href: '/pwa/',
    statuses: [
      { status: 'stable', label: ui.v26Stable },
      { status: 'beta', label: ui.v26Beta },
    ],
  },
  {
    icon: '◫',
    title: 'iOS',
    description: 'iOS/iPadOS 17+',
    href: '/ios/',
    statuses: [{ status: 'beta', label: ui.beta }],
  },
  {
    icon: '△',
    title: 'Android',
    description: 'Android API 26+',
    href: '/android/',
    statuses: [{ status: 'beta', label: ui.beta }],
  },
] as const;
---

<home-search-launcher class="search-launch">
  <form class="home-search-field" role="search">
    <button type="submit" aria-label={searchText}><span aria-hidden="true">⌕</span></button>
    <input
      type="search"
      id="home-search"
      name="q"
      placeholder={searchText}
      aria-label={searchText}
      autocomplete="off"
    />
    <kbd aria-hidden="true">/</kbd>
  </form>
</home-search-launcher>
<div class="route-grid">
  {
    routes.map((route) => (
      <a href={`${prefix}${route.href}`}>
        <span class="route-icon" aria-hidden="true">
          {route.icon}
        </span>
        <strong>{route.title}</strong>
        <span class="route-description">{route.description}</span>
        <span class="route-status">
          {route.statuses.map(({ status, label }) => (
            <StatusBadge status={status} label={label} />
          ))}
        </span>
      </a>
    ))
  }
</div>
<script>
  class HomeSearchLauncher extends HTMLElement {
    private abortController = new AbortController();

    connectedCallback() {
      const form = this.querySelector('form');
      const input = this.querySelector('input[type="search"]');
      if (!(form instanceof HTMLFormElement) || !(input instanceof HTMLInputElement)) return;

      form.addEventListener(
        'submit',
        (event) => {
          event.preventDefault();
          void this.openSearch(input.value);
        },
        { signal: this.abortController.signal },
      );

      document.addEventListener(
        'keydown',
        (event) => {
          if (event.key !== '/' || event.metaKey || event.ctrlKey || event.altKey) return;
          const target = event.target;
          if (
            target instanceof HTMLInputElement ||
            target instanceof HTMLTextAreaElement ||
            (target instanceof HTMLElement && target.isContentEditable)
          )
            return;

          event.preventDefault();
          input.focus();
        },
        { signal: this.abortController.signal },
      );
    }

    disconnectedCallback() {
      this.abortController.abort();
    }

    private async openSearch(query: string) {
      await customElements.whenDefined('site-search');
      const trigger = document.querySelector('site-search button[data-open-modal]');
      if (!(trigger instanceof HTMLButtonElement)) return;

      trigger.click();
      const pagefindInput = await this.waitForPagefindInput();
      if (!pagefindInput) return;

      pagefindInput.value = query;
      pagefindInput.dispatchEvent(new Event('input', { bubbles: true }));
      pagefindInput.focus();
    }

    private waitForPagefindInput(): Promise<HTMLInputElement | null> {
      const existing = document.querySelector('#starlight__search input');
      if (existing instanceof HTMLInputElement) return Promise.resolve(existing);

      return new Promise((resolve) => {
        const signal = this.abortController.signal;
        let observer: MutationObserver;
        const finish = (input: HTMLInputElement | null) => {
          observer.disconnect();
          signal.removeEventListener('abort', cancel);
          resolve(input);
        };
        const cancel = () => finish(null);
        observer = new MutationObserver(() => {
          const input = document.querySelector('#starlight__search input');
          if (input instanceof HTMLInputElement) finish(input);
        });

        signal.addEventListener('abort', cancel, { once: true });
        observer.observe(document.body, { childList: true, subtree: true });
      });
    }
  }

  if (!customElements.get('home-search-launcher'))
    customElements.define('home-search-launcher', HomeSearchLauncher);
</script>
