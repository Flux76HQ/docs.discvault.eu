---
import EditLink from '@astrojs/starlight/components/EditLink.astro';
import LastUpdated from '@astrojs/starlight/components/LastUpdated.astro';
import Pagination from '@astrojs/starlight/components/Pagination.astro';
import { currentLocale, labels } from '../data/localized-ui';

const defaultFeedbackUrl = 'https://github.com/Flux76HQ/docs.discvault.eu/issues/new';
const configuredFeedbackUrl = import.meta.env.PUBLIC_FEEDBACK_URL?.trim();
let feedbackUrl = defaultFeedbackUrl;

if (configuredFeedbackUrl) {
  try {
    const candidate = new URL(configuredFeedbackUrl);
    if (candidate.protocol === 'https:') feedbackUrl = candidate.href;
  } catch {
    // Invalid public configuration falls back to the repository issue form.
  }
}

const locale = currentLocale(Astro.url.pathname);
const feedbackLabel = labels[locale].feedback;
---

<footer class="docs-footer sl-flex">
  <div class="meta sl-flex">
    <div class="contribution-links sl-flex">
      <EditLink />
      <a class="feedback-link sl-flex print:hidden" href={feedbackUrl} aria-label={feedbackLabel}>
        <svg aria-hidden="true" viewBox="0 0 24 24" width="1.2em" height="1.2em">
          <path
            fill="currentColor"
            d="M4 3h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H9l-5 4v-4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Zm1 2v10h1v1.8L8.25 15H19V5H5Zm3 3h8v2H8V8Zm0 4h5v2H8v-2Z"
          ></path>
        </svg>
        <span>{feedbackLabel}</span>
      </a>
    </div>
    <LastUpdated />
  </div>
  <Pagination />
</footer>

<style>
  @layer starlight.core {
    .docs-footer {
      flex-direction: column;
      gap: 1.5rem;
    }
    .meta {
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem 3rem;
      justify-content: space-between;
      margin-top: 3rem;
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-sm);
    }
    .contribution-links {
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem 1.5rem;
    }
    .feedback-link {
      align-items: center;
      gap: 0.5rem;
      min-height: 44px;
      color: var(--sl-color-gray-3);
      text-decoration: none;
    }
    .feedback-link:hover {
      color: var(--sl-color-white);
    }
  }
</style>
