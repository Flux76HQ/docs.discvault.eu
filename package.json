{
  "name": "discvault-documentation",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && node scripts/check_content.mjs && node scripts/check_translations.mjs && node scripts/check_links.mjs && node scripts/check_contrast.mjs && node scripts/check_version_bump.mjs",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "content:check": "node scripts/check_content.mjs",
    "translations:check": "node scripts/check_translations.mjs",
    "contrast:check": "node scripts/check_contrast.mjs",
    "links:check": "node scripts/check_links.mjs",
    "credentials:check": "node scripts/check_credentials.mjs",
    "smoke": "node scripts/smoke_build.mjs",
    "version:bump": "node scripts/bump_version.mjs",
    "version:check": "node scripts/check_version_bump.mjs",
    "hooks:setup": "node scripts/setup_hooks.mjs",
    "content:generate": "node scripts/generate_content.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/starlight": "^0.36.0",
    "@fontsource-variable/inter": "^5.2.6",
    "astro": "^6.4.6",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@astrojs/check": "^0.9.4",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3"
  }
}
